{
  "compilerOptions": {
    "target": "es5",
    "module": "es6",
    "moduleResolution": "node",
    // es5 target + node10 resolution are intentional for broad compatibility
    // (engines.node >= 6.10, legacy browsers, classic `types`/`main` resolution).
    // TypeScript 6.0 deprecated both; suppress until a deliberate compat change.
    "ignoreDeprecations": "6.0",
    "sourceMap": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "esm",
    "allowSyntheticDefaultImports": true,
    "removeComments": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "experimentalDecorators": true
  },
  "files": [
    "node_modules/typescript/lib/lib.es2015.d.ts",
    "node_modules/typescript/lib/lib.dom.d.ts",
    "src/index.ts"
  ],
  "include": [
    "*.ts",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "*/__tests__",
    "*/__mocks__",
    "dist"
  ]
}
